{
  "name": "gloomberb",
  "version": "0.3.0",
  "description": "Bloomberg-style stock portfolio tracker for the terminal",
  "module": "src/index.tsx",
  "type": "module",
  "bin": {
    "gloomberb": "bin/gloomberb"
  },
  "files": [
    "bin",
    "src",
    "patches"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "start": "bun src/index.tsx",
    "build": "bun run scripts/build.ts",
    "build:all": "bun run scripts/build.ts --all",
    "test": "bun test",
    "release": "./scripts/release.sh"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vincelwt/gloomberb"
  },
  "keywords": [
    "terminal",
    "tui",
    "stocks",
    "portfolio",
    "bloomberg",
    "finance"
  ],
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui-ui/dialog": "^0.1.2",
    "@opentui-ui/toast": "^0.0.5",
    "@opentui/core": "^0.1.90",
    "@opentui/react": "^0.1.90",
    "@stoqey/ib": "^1.5.3",
    "gray-matter": "^4.0.3",
    "opentui-spinner": "^0.0.6",
    "react": "^19.2.4",
    "yahoo-finance2": "^3.13.2"
  },
  "patchedDependencies": {
    "@opentui/core@0.1.90": "patches/@opentui%2Fcore@0.1.90.patch"
  }
}
