{
  "name": "gloomberb",
  "version": "0.9.1",
  "description": "Market research and portfolio tracker for the terminal",
  "module": "src/index.tsx",
  "type": "module",
  "bin": {
    "gloomberb": "bin/gloomberb"
  },
  "files": [
    "bin",
    "src",
    "patches"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "start": "bun src/index.tsx",
    "build": "bun run scripts/build.ts",
    "build:all": "bun run scripts/build.ts --all",
    "desktop:view:build": "bun run scripts/build-electrobun-view.ts",
    "desktop:dev": "electrobun dev --watch",
    "desktop:build": "electrobun build",
    "desktop:release": "electrobun build --env=stable",
    "desktop:release:windows": "electrobun build --env=stable --targets=win-x64",
    "test": "bun test",
    "release": "./scripts/release.sh"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vincelwt/gloomberb"
  },
  "keywords": [
    "terminal",
    "tui",
    "stocks",
    "portfolio",
    "finance"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react-dom": "^19.2.3",
    "electrobun": "^1.18.1",
    "png-to-ico": "^2.1.8",
    "rcedit": "^4.0.1",
    "react-dom": "19.2.7"
  },
  "peerDependencies": {
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@opentui-ui/dialog": "^0.1.2",
    "@opentui-ui/toast": "^0.0.5",
    "@opentui/core": "^0.3.2",
    "@opentui/react": "^0.3.2",
    "@stoqey/ib": "^1.5.6",
    "@tanstack/react-virtual": "^3.14.2",
    "jimp": "1.6.1",
    "opentui-spinner": "^0.0.6",
    "react": "19.2.7",
    "rxjs": "^7.8.2",
    "web-tree-sitter": "0.25.10"
  },
  "patchedDependencies": {
    "@opentui/core@0.3.2": "patches/@opentui%2Fcore@0.3.2.patch",
    "electrobun@1.18.1": "patches/electrobun@1.18.1.patch"
  }
}
