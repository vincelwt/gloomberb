{
  "name": "gloomberb",
  "version": "0.1.0",
  "description": "Bloomberg-style stock portfolio tracker for the terminal",
  "module": "src/index.tsx",
  "type": "module",
  "bin": {
    "gloomberb": "bin/gloomberb"
  },
  "files": [
    "bin",
    "install.mjs"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "build": "bun run scripts/build.ts",
    "build:all": "bun run scripts/build.ts --all",
    "postinstall": "node install.mjs"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vincelwt/gloomberb"
  },
  "keywords": [
    "terminal",
    "tui",
    "stocks",
    "portfolio",
    "bloomberg",
    "finance"
  ],
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui-ui/dialog": "^0.1.2",
    "@opentui/core": "^0.1.90",
    "@opentui/react": "^0.1.90",
    "gray-matter": "^4.0.3",
    "react": "^19.2.4",
    "yahoo-finance2": "^3.13.2"
  }
}